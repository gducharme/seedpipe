{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "seedpipe://spec/phase1/contracts/artifact_ref.schema.json",
  "title": "ArtifactRef",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "path", "hash", "schema_version", "produced_by"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Logical artifact name as used in pipeline.yaml (e.g. items.jsonl)."
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the artifact file, relative to the current working directory unless absolute."
    },
    "hash": {
      "type": "string",
      "minLength": 8,
      "description": "Content hash of the artifact bytes. Format: '<algo>:<hex>' (e.g. 'sha256:...').",
      "pattern": "^[a-z0-9]+:[0-9a-f]{8,}$"
    },
    "bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional size in bytes."
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Semantic version (or hash) identifying the artifact's contract schema used for validation."
    },
    "produced_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "stage_id"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "stage_id": { "type": "string", "minLength": 1 },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "description": "Attempt number for idempotent executions. 1-based."
        }
      },
      "description": "Provenance for the artifact."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional RFC3339 timestamp for when the artifact was committed."
    }
  }
}
