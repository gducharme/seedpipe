{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stripe Invoice Row (Future)",
  "description": "Proposed Phase 4 contract for normalized Stripe invoice rows used in cost reconciliation.",
  "type": "object",
  "required": [
    "stripe_account_id",
    "invoice_id",
    "invoice_status",
    "invoice_currency",
    "invoice_total",
    "invoice_created_at",
    "window_start",
    "window_end"
  ],
  "properties": {
    "stripe_account_id": {"type": "string", "minLength": 1},
    "invoice_id": {"type": "string", "minLength": 1},
    "invoice_status": {"type": "string", "enum": ["draft", "open", "paid", "void", "uncollectible"]},
    "invoice_currency": {"type": "string", "minLength": 3, "maxLength": 3},
    "invoice_subtotal": {"type": "number"},
    "invoice_total": {"type": "number"},
    "invoice_created_at": {"type": "string", "format": "date-time"},
    "invoice_finalized_at": {"type": ["string", "null"], "format": "date-time"},
    "window_start": {"type": "string", "format": "date-time"},
    "window_end": {"type": "string", "format": "date-time"},
    "line_count": {"type": "integer", "minimum": 0},
    "raw_ref": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
