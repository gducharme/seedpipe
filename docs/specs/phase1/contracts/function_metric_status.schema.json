{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Function Metric Status",
  "description": "Schema for per-function metric status summary with eligibility determination",
  "type": "object",
  "properties": {
    "function_id": {
      "type": "string"
    },
    "eligible_for_comparison": {
      "type": "boolean"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_id": {
      "type": "string"
    },
    "max_age_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "policy_id", "severity", "message"],
        "properties": {
          "finding_id": {"type": "string"},
          "policy_id": {"type": "string"},
          "severity": {"type": "string", "enum": ["error", "warning"]},
          "metric_name": {"type": "string"},
          "message": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "metrics_present": {
      "type": "object",
      "properties": {
        "latency": {"type": ["boolean", "null"]},
        "cost": {"type": ["boolean", "null"]},
        "success_count": {"type": ["boolean", "null"]},
        "failure_count": {"type": ["boolean", "null"]},
        "quality_rating": {"type": ["boolean", "null"]}
      }
    }
  },
  "required": ["function_id", "eligible_for_comparison", "last_updated_at", "policy_id", "max_age_seconds", "findings"],
  "additionalProperties": false
}
