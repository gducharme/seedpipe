{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "seedpipe://spec/phase1/contracts/manifest.schema.json",
  "title": "SeedpipeRunManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "run_id",
    "pipeline_id",
    "code_version",
    "config_hash",
    "inputs",
    "stage_outputs",
    "created_at"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "phase1-v0",
      "description": "Manifest contract version for Phase 1."
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this run."
    },
    "pipeline_id": {
      "type": "string",
      "minLength": 1,
      "description": "Must match pipeline.yaml pipeline_id."
    },
    "pipeline_spec_hash": {
      "type": "string",
      "description": "Optional hash of the pipeline.yaml bytes for determinism tracking.",
      "pattern": "^[a-z0-9]+:[0-9a-f]{8,}$"
    },
    "code_version": {
      "type": "string",
      "minLength": 1,
      "description": "Exact code identifier (e.g., git SHA or build id)."
    },
    "config_hash": {
      "type": "string",
      "description": "Hash of resolved config/manifest inputs used for this run.",
      "pattern": "^[a-z0-9]+:[0-9a-f]{8,}$"
    },
    "determinism_policy": {
      "type": "string",
      "enum": ["strict", "best_effort"],
      "default": "strict",
      "description": "Effective determinism policy enforced for this run."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 timestamp when the manifest was committed."
    },
    "inputs": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "seedpipe://spec/phase1/contracts/artifact_ref.schema.json" },
      "description": "External or initial artifacts treated as inputs to the run."
    },
    "stage_outputs": {
      "type": "array",
      "minItems": 0,
      "description": "Outputs produced per stage (verifier uses this to validate write-once + provenance).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage_id", "outputs"],
        "properties": {
          "stage_id": { "type": "string", "minLength": 1 },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "seedpipe://spec/phase1/contracts/artifact_ref.schema.json" }
          }
        }
      }
    },
    "final_outputs": {
      "type": "array",
      "description": "Optional convenience list: subset of stage outputs considered final deliverables.",
      "items": { "$ref": "seedpipe://spec/phase1/contracts/artifact_ref.schema.json" }
    },
    "notes": {
      "type": "string",
      "maxLength": 8000,
      "description": "Optional human notes (non-semantic)."
    }
  }
}
