{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "seedpipe/contracts/inbox_bundle.schema.json",
  "title": "InboxBundle",
  "type": "object",
  "additionalProperties": true,
  "required": ["bundle_id", "pipeline_id", "created_at_utc", "artifacts"],
  "properties": {
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\.\\.).+"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
