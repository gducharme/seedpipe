{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Function Metric Status",
  "description": "Schema for per-function metric status summary with eligibility determination",
  "type": "object",
  "properties": {
    "function_id": {
      "type": "string"
    },
    "eligible_for_comparison": {
      "type": "boolean"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "type": "object",
      "properties": {
        "latency": {"type": ["number", "null"]},
        "cost": {"type": ["number", "null"]},
        "success_count": {"type": ["integer", "null"]},
        "failure_count": {"type": ["integer", "null"]},
        "quality_rating": {"type": ["number", "null"]}
      }
    },
    "reasons": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "required": ["function_id", "eligible_for_comparison", "last_updated_at", "reasons"],
  "additionalProperties": false
}
